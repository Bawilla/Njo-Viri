{
  "instruction_type": "grammar_rule",
  "grammar_name": "balanda_cardinal_numbers",
  "description": "This file contains Balanda cardinal numbers and rules for number formation. Balanda numbers are formed using base numerals and additive composition.",
  "rules": {
    "base_numbers": {
      "function": "base numbers",
      "structure": "{\"0\": \"Waya\", \"1\": \"Nzee\", \"2\": \"Soo\", \"3\": \"Tau\", \"4\": \"Nau\", \"5\": \"Voo\", \"6\": \"Vonzee\", \"7\": \"Vosoo\", \"8\": \"Votau\", \"9\": \"Vonau\", \"10\": \"Bikur\", \"20\": \"Vetdi\"}",
      "notes": "Waya | Nzee | Soo | Tau | Nau | Voo | Vonzee | Vosoo | Votau | Vonau | Bikur | Vetdi"
    },
    "number_formation": {
      "function": "number formation",
      "structure": "{\"11_to_19\": {\"structure\": \"Bikur + Unit\", \"rule\": \"Numbers from 11 to 19 are formed by combining 'Bikur' (ten) with a unit number\", \"example\": \"Bikur nzee = eleven\"}, \"21_to_29\": {\"structure\": \"Vetdi + Unit\", \"rule\": \"Numbers from 21 to 29 are formed by combining 'Vetdi' (twenty) with a unit number\", \"example\": \"Vetdi tau = twenty-three\"}}",
      "notes": ""
    },
    "composition_principle": {
      "function": "composition principle",
      "structure": "Additive; higher base number precedes the unit number",
      "notes": ""
    },
    "word_order": {
      "function": "word order",
      "structure": "Base number followed by unit number",
      "notes": ""
    },
    "constraints": {
      "function": "constraints",
      "structure": "Unit numbers do not change form when combined; No conjunction is used between number elements; Numbers are written as separate words; Incorrect unit forms must be corrected to the standard base numerals",
      "notes": ""
    }
  }
}
