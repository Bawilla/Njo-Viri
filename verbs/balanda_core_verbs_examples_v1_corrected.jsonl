{
  "instruction_type": "grammar_rule",
  "grammar_name": "balanda_infinitive_to_finite_mapping",
  "description": "This file demonstrates how Balanda infinitive verbs (A-VERB) are converted into finite present-tense sentence forms. The infinitive prefix 'A-' is removed and replaced with appropriate tense, aspect, negation, or question markers.",
  "rules": {
    "base_principle": {
      "function": "base principle",
      "structure": "Infinitive verbs (A-VERB) cannot appear directly in sentences. To form a sentence, the prefix 'A-' must be removed and replaced by finite morphology.",
      "notes": ""
    },
    "present_simple": {
      "function": "present simple",
      "structure": "Subject + VERB + Object/Complement",
      "notes": ""
    },
    "present_continuous": {
      "function": "present continuous",
      "structure": "Subject + no + ti-VERB + Object/Complement",
      "notes": ""
    },
    "negation": {
      "function": "negation",
      "structure": "Subject + VERB + Object/Complement + gba",
      "notes": ""
    },
    "question": {
      "function": "question",
      "structure": "Subject + VERB + Object/Complement + we?",
      "notes": ""
    },
    "constraints": {
      "function": "constraints",
      "structure": "The prefix 'A-' must always be removed in finite clauses; Infinitives must not appear with tense, aspect, or modal markers; ti- is used only in continuous aspect; no marks present continuous aspect; gba marks negation and must appear clause-finally; we? marks questions and must appear at the end of the sentence; No inversion or auxiliary movement occurs in questions",
      "notes": ""
    }
  }
}
