      "proper noun",
      "pronoun"
    ],
    "adjective_behavior": "Adjective functions as predicate and does not require a verb meaning 'to be'",
    "tense_interpretation": "Default interpretation is present or timeless state unless tense markers are added in other constructions",
    "agreement": "No agreement marking appears on the adjective for number, gender, or person",
    "constraints": [
      "No copular verb is used in this construction",
      "No tense or aspect prefix appears in this file",
      "Word order remains Subject + Adjective",
      "Adjectives express permanent or temporary qualities",
      "Pronoun subjects follow the same structure as noun subjects"
    ]
  }
}


