{
  "instruction_type": "grammar_rule",
  "grammar_name": "balanda_noun_adjective_predication",
  "description": "This file contains Balanda noun–adjective predication clauses. These sentences describe qualities or states of a subject using a noun or pronoun followed directly by an adjective.",
  "rules": {
    "basic_structure": {
      "function": "basic structure",
      "structure": "Subject (Noun or Pronoun) + Adjective",
      "notes": ""
    },
    "word_order": {
      "function": "word order",
      "structure": "Predicate adjective follows the subject directly with no copula",
      "notes": ""
    },
    "subject_type": {
      "function": "subject type",
      "structure": "common noun; proper noun; pronoun",
      "notes": ""
    },
    "adjective_behavior": {
      "function": "adjective behavior",
      "structure": "Adjective functions as predicate and does not require a verb meaning 'to be'",
      "notes": ""
    },
    "tense_interpretation": {
      "function": "tense interpretation",
      "structure": "Default interpretation is present or timeless state unless tense markers are added in other constructions",
      "notes": ""
    },
    "agreement": {
      "function": "agreement",
      "structure": "No agreement marking appears on the adjective for number, gender, or person",
      "notes": ""
    },
    "constraints": {
      "function": "constraints",
      "structure": "No copular verb is used in this construction; No tense or aspect prefix appears in this file; Word order remains Subject + Adjective; Adjectives express permanent or temporary qualities; Pronoun subjects follow the same structure as noun subjects",
      "notes": ""
    }
  }
}
