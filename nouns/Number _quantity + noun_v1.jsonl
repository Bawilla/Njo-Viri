{
  "instruction_type": "grammar_rule",
  "grammar_name": "balanda_number_quantity_noun",
  "description": "This file contains Balanda number and quantity constructions. Number and quantity modify nouns, and plural nouns are formed by prefixing ka- to the noun.",
  "rules": {
    "plural_formation": {
      "marker": "ka-",
      "structure": "ka + Noun",
      "function": "Marks plural nouns",
      "constraints": [
        "ka- must attach directly to the noun",
        "Singular nouns appear without ka-",
        "Plural marking appears on the noun, not on numbers or quantifiers"
      ]
    },
    "numeral_construction": {
      "structure": "Noun + Numeral (singular) | ka-Noun + Numeral (plural)",
      "numeral_position": "Numeral follows the noun",
      "singular_usage": "The numeral 'nzee' (one) is used only with singular nouns",
      "plural_usage": "Numerals greater than one require ka- on the noun"
    },
    "quantity_construction": {
      "structure": "Quantity + (ka-)Noun | Noun + Quantity",
      "quantity_types": [
        "koti (many)",
        "roko (few)",
        "bihi (some)",
        "kpi (all)",
        "willa (none)",
        "sutu (much)",
        "fitti (little)"
      ],
      "mass_vs_count": "Mass nouns typically do not take ka-; count nouns do",
      "word_order_variation": "Some quantities precede the noun, others follow the noun depending on lexical item"
    },
    "tense_interpretation": "Number and quantity constructions are atemporal and do not encode tense or aspect",
    "constraints": [
      "Numerals do not change form for gender or noun class",
      "Plurality is encoded only by ka-",
      "Quantity words do not replace plural marking on count nouns",
      "No copula or verb is used in pure number/quantity expressions"
    ]
  }
}



