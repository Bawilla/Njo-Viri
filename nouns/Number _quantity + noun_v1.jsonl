{
  "instruction_type": "grammar_rule",
  "grammar_name": "balanda_number_quantity_noun",
  "description": "This file contains Balanda number and quantity constructions. Number and quantity modify nouns, and plural nouns are formed by prefixing ka- to the noun.",
  "rules": {
    "plural_formation": {
      "function": "Marks plural nouns",
      "structure": "ka + Noun",
      "notes": "ka- | ka- must attach directly to the noun; Singular nouns appear without ka-; Plural marking appears on the noun, not on numbers or quantifiers"
    },
    "numeral_construction": {
      "function": "numeral construction",
      "structure": "Noun + Numeral (singular) | ka-Noun + Numeral (plural)",
      "notes": "Numeral follows the noun | The numeral 'nzee' (one) is used only with singular nouns | Numerals greater than one require ka- on the noun"
    },
    "quantity_construction": {
      "function": "quantity construction",
      "structure": "Quantity + (ka-)Noun | Noun + Quantity",
      "notes": "koti (many); roko (few); bihi (some); kpi (all); willa (none); sutu (much); fitti (little) | Mass nouns typically do not take ka-; count nouns do | Some quantities precede the noun, others follow the noun depending on lexical item"
    },
    "tense_interpretation": {
      "function": "tense interpretation",
      "structure": "Number and quantity constructions are atemporal and do not encode tense or aspect",
      "notes": ""
    },
    "constraints": {
      "function": "constraints",
      "structure": "Numerals do not change form for gender or noun class; Plurality is encoded only by ka-; Quantity words do not replace plural marking on count nouns; No copula or verb is used in pure number/quantity expressions",
      "notes": ""
    }
  }
}
