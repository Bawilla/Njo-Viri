{
  "instruction_type": "grammar_rule",
  "grammar_name": "balanda_noun_possessor_construction",
  "description": "This file contains Balanda noun–possessor constructions. Possession is expressed by placing the possessed noun first, followed by the possessive particle 'ngandi', and then the possessor noun or pronoun.",
  "rules": {
    "basic_structure": "Possessed Noun + ngandi + Possessor (Noun or Pronoun)",
    "possessive_particle": "ngandi",
    "word_order": "Head-first (possessed item precedes possessor)",
    "possessor_type": [
      "pronoun",
      "common noun",
      "proper noun"
    ],
    "possessive_relationship": "Expresses ownership, association, or inherent relation",
    "tense_interpretation": "Possessive constructions are atemporal and do not encode tense or aspect",
    "constraints": [
      "ngandi must always appear between the possessed noun and the possessor",
      "No copula is used in possessive constructions",
      "No tense, aspect, or negation markers appear in this construction",
      "Word order is fixed and must not be inverted",
      "Plurality and definiteness are inferred from context"
    ]
  }
}



