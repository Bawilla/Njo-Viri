{
  "instruction_type": "grammar_rule",
  "grammar_name": "balanda_noun_possessor_construction",
  "description": "This file contains Balanda noun–possessor constructions. Possession is expressed by placing the possessed noun first, followed by the possessive particle 'ngandi', and then the possessor noun or pronoun.",
  "rules": {
    "basic_structure": {
      "function": "basic structure",
      "structure": "Possessed Noun + ngandi + Possessor (Noun or Pronoun)",
      "notes": ""
    },
    "possessive_particle": {
      "function": "possessive particle",
      "structure": "ngandi",
      "notes": ""
    },
    "word_order": {
      "function": "word order",
      "structure": "Head-first (possessed item precedes possessor)",
      "notes": ""
    },
    "possessor_type": {
      "function": "possessor type",
      "structure": "pronoun; common noun; proper noun",
      "notes": ""
    },
    "possessive_relationship": {
      "function": "possessive relationship",
      "structure": "Expresses ownership, association, or inherent relation",
      "notes": ""
    },
    "tense_interpretation": {
      "function": "tense interpretation",
      "structure": "Possessive constructions are atemporal and do not encode tense or aspect",
      "notes": ""
    },
    "constraints": {
      "function": "constraints",
      "structure": "ngandi must always appear between the possessed noun and the possessor; No copula is used in possessive constructions; No tense, aspect, or negation markers appear in this construction; Word order is fixed and must not be inverted; Plurality and definiteness are inferred from context",
      "notes": ""
    }
  }
}
