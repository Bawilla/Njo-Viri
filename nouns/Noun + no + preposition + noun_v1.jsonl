{
  "instruction_type": "grammar_rule",
  "grammar_name": "balanda_locative_predication",
  "description": "This file contains Balanda locative predication clauses. These sentences describe the location of a subject using the copular particle 'no' followed by a locative preposition and its object.",
  "rules": {
    "basic_structure": {
      "function": "basic structure",
      "structure": "Subject (Noun) + no + Preposition + Locative Object",
      "notes": ""
    },
    "copular_particle": {
      "function": "copular particle",
      "structure": "no",
      "notes": ""
    },
    "function": {
      "function": "function",
      "structure": "Expresses location or spatial relation of the subject",
      "notes": ""
    },
    "preposition_role": {
      "function": "preposition role",
      "structure": "Encodes spatial relationship (in, under, behind, on, above, near, in front of, beside)",
      "notes": ""
    },
    "word_order": {
      "function": "word order",
      "structure": "Fixed; no inversion or movement",
      "notes": ""
    },
    "tense_interpretation": {
      "function": "tense interpretation",
      "structure": "Present or timeless state unless modified by tense markers in other constructions",
      "notes": ""
    },
    "constraints": {
      "function": "constraints",
      "structure": "The particle 'no' must appear between the subject and the preposition; Prepositions must be followed by a locative object; No tense or aspect marking appears in this construction; No negation appears in this file; Plurality and definiteness are inferred from context; This construction is distinct from possession and nominal predication",
      "notes": ""
    }
  }
}
