{
  "instruction_type": "grammar_rule",
  "grammar_name": "balanda_noun_verb_basic_clauses",
  "description": "This file contains basic Balanda noun–verb clauses. These sentences express simple actions or states with a noun or pronoun subject followed directly by a verb, optionally with an object or complement.",
  "rules": {
    "basic_structure": {
      "function": "basic structure",
      "structure": "Subject (Noun or Pronoun) + Verb + (Object/Complement)",
      "notes": ""
    },
    "word_order": {
      "function": "word order",
      "structure": "SVO (Subject–Verb–Object) when an object is present",
      "notes": ""
    },
    "subject_type": {
      "function": "subject type",
      "structure": "common noun; proper noun; pronoun",
      "notes": ""
    },
    "verb_behavior": {
      "function": "verb behavior",
      "structure": "Verb appears in bare form with no tense or aspect marker unless specified elsewhere",
      "notes": ""
    },
    "object_behavior": {
      "function": "object behavior",
      "structure": "Object is optional and follows the verb",
      "notes": ""
    },
    "prepositional_phrases": {
      "function": "prepositional phrases",
      "structure": "Locative or directional phrases follow the verb or object",
      "notes": ""
    },
    "tense_interpretation": {
      "function": "tense interpretation",
      "structure": "Default tense is generic or present unless overridden by explicit tense markers in other files",
      "notes": ""
    },
    "constraints": {
      "function": "constraints",
      "structure": "No tense or aspect prefixes are used in this file; No copula is used; Word order does not change for different subjects; Plurality is inferred from the subject, not verb morphology; Sentences may be transitive or intransitive",
      "notes": ""
    }
  }
}
