{
  "instruction_type": "grammar_rule",
  "grammar_name": "balanda_noun_noun_predication_and_modification",
  "description": "This file contains Balanda noun–noun constructions. These include (1) nominal predication using the copular particle 'no' and (2) noun–noun modification without a copula.",
  "rules": {
    "construction_types": {
      "nominal_predication": {
        "structure": "Subject (Noun or Pronoun) + no + Noun",
        "function": "Identifies or classifies the subject as a member of a category",
        "copula": "no",
        "tense_interpretation": "present or timeless identification",
        "examples": [
          "Ni no diktor",
          "Ni no gbiya"
        ]
      },
      "noun_noun_modification": {
        "structure": "Modifier Noun + Head Noun",
        "function": "Describes a quality, type, or classification of the head noun",
        "copula": "none",
        "word_order": "Modifier precedes head noun",
        "examples": [
          "Gbito bura",
          "zongo wiki"
        ]
      }
    },
    "constraints": [
      "The particle 'no' is used only for nominal predication",
      "No copula appears in noun–noun modification",
      "Word order is fixed within each construction",
      "Plurality and definiteness are inferred from context",
      "These constructions do not carry tense or aspect marking"
    ]
  }
}


