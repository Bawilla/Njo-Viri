{
  "instruction_type": "grammar_rule",
  "grammar_name": "balanda_past_continuous_questions",
  "description": "This file defines yes–no question formation in the Past Continuous tense in Njo Viri (Balanda). Past continuous questions ask whether an action was ongoing at a specific point in the past.",
  "rules": {
    "general_principle": {
      "statement": "Past continuous questions in Balanda are formed by retaining the affirmative past continuous structure and adding the question marker 'we?' at the end of the sentence."
    },

    "question_structure": {
      "structure": "Subject + noka + ti-Verb + (Object / Complement) + we?",
      "description": "Used to ask whether an action was in progress in the past.",
      "constraints": [
        "The auxiliary 'noka' must be present",
        "The prefix 'ti-' must attach to the verb",
        "The question marker 'we?' must appear sentence-final"
      ]
    },

    "aspect_preservation": {
      "rule": "The progressive prefix 'ti-' is mandatory in all past continuous questions.",
      "constraints": [
        "ti- cannot be omitted",
        "questions do not change aspectual meaning"
      ]
    },

    "word_order_rules": {
      "rule": "Question formation does not change word order.",
      "note": "Balanda does not use subject–auxiliary inversion."
    },

    "error_constraints": [
      "Do not omit 'noka'",
      "Do not omit 'ti-'",
      "Do not place 'we?' inside the sentence",
      "Do not replace 'noka' with 'no'",
      "Do not use bare verb forms"
    ],

    "model_behavior_guidelines": {
      "keep_word_order_fixed": true,
      "enforce_question_marker_final": true,
      "preserve_progressive_aspect": true
    }
  }
}

