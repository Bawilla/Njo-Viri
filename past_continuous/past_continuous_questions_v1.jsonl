{
  "instruction_type": "grammar_rule",
  "grammar_name": "balanda_past_continuous_questions",
  "description": "This file defines yes–no question formation in the Past Continuous tense in Njo Viri (Balanda). Past continuous questions ask whether an action was ongoing at a specific point in the past.",
  "rules": {
    "general_principle": {
      "function": "general principle",
      "structure": "Past continuous questions in Balanda are formed by retaining the affirmative past continuous structure and adding the question marker 'we?' at the end of the sentence.",
      "notes": ""
    },
    "question_structure": {
      "function": "question structure",
      "structure": "Subject + noka + ti-Verb + (Object / Complement) + we?",
      "notes": "Used to ask whether an action was in progress in the past. | The auxiliary 'noka' must be present; The prefix 'ti-' must attach to the verb; The question marker 'we?' must appear sentence-final"
    },
    "aspect_preservation": {
      "function": "aspect preservation",
      "structure": "The progressive prefix 'ti-' is mandatory in all past continuous questions.",
      "notes": "ti- cannot be omitted; questions do not change aspectual meaning"
    },
    "word_order_rules": {
      "function": "word order rules",
      "structure": "Question formation does not change word order.",
      "notes": "Balanda does not use subject–auxiliary inversion."
    },
    "error_constraints": {
      "function": "error constraints",
      "structure": "Do not omit 'noka'; Do not omit 'ti-'; Do not place 'we?' inside the sentence; Do not replace 'noka' with 'no'; Do not use bare verb forms",
      "notes": ""
    },
    "model_behavior_guidelines": {
      "function": "model behavior guidelines",
      "structure": "{\"keep_word_order_fixed\": true, \"enforce_question_marker_final\": true, \"preserve_progressive_aspect\": true}",
      "notes": ""
    }
  }
}
