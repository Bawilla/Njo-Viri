{
  "instruction_type": "grammar_rule",
  "grammar_name": "balanda_past_continuous",
  "description": "This file defines the Past Continuous tense in Njo Viri (Balanda). The tense is used to express actions that were ongoing at a specific point in the past. It is formed using the auxiliary 'noka' and the verbal prefix 'ti-'.",
  "rules": {
    "general_principle": {
      "statement": "Past continuous tense in Balanda is marked by the auxiliary 'noka' combined with the prefix 'ti-' attached to the verb. It expresses actions that were in progress in the past."
    },

    "affirmative_structure": {
      "structure": "Subject + noka + ti-Verb + (Object / Complement)",
      "description": "Used to describe an action that was ongoing in the past.",
      "examples": [
        "Ne noka tidhe kümü",
        "Ne noka timoliki gbi difo",
        "Ni noka tinangele zanga",
        "Uku noka timande gbi njü",
        "Ne noka timerego ŋo"
      ]
    },

    "negation": {
      "description": "Negation in the past continuous can be expressed using two licensed strategies.",
      "patterns": {
        "maka_gba_pattern": {
          "structure": "Subject + maka + ti-Verb + (Object) + gba",
          "examples": [
            "Ne maka timoliki gbi difo gba",
            "Ni maka tinangele zanga gba",
            "Afo maka timande gbi njü gba"
          ]
        },
        "kawilla_pattern": {
          "structure": "Subject + kawilla + ti-Verb + (Object)",
          "examples": [
            "Ne kawilla timerego ŋo",
            "Uku kawilla timele vongu"
          ]
        }
      }
    },

    "questions": {
      "description": "Yes–no questions in the past continuous are formed by adding the question marker 'we?' at the end of the sentence.",
      "structure": "Subject + noka + ti-Verb + (Object) + we?",
      "examples": [
        "Ne noka timoliki gbi difo we?",
        "Ni noka tikulu munja we?",
        "Uku noka timande gbi njü we?"
      ]
    },

    "negative_questions": {
      "description": "Negative past continuous questions retain the negation strategy and add 'we?' sentence-finally.",
      "examples": [
        "Yehe ni kawilla tiriki dha we?",
        "Ne kawilla tiwutduru kese ngande’e ta kavokau we?",
        "Ni kawilla tiyele tamma we?"
      ]
    },

    "verb_morphology": {
      "rule": "The prefix 'ti-' must attach directly to the verb root in all past continuous constructions.",
      "constraints": [
        "ti- cannot be omitted",
        "bare verbs do not express past continuous meaning"
      ],
      "examples": [
        "timande (was working)",
        "tinangele (was running)",
        "timerego (was loving)"
      ]
    },

    "sentence_identification": {
      "affirmative": "Subject + noka + ti-Verb",
      "negative": "Subject + maka + ti-Verb + gba OR Subject + kawilla + ti-Verb",
      "question": "Subject + noka + ti-Verb + we?",
      "negative_question": "Negative sentence + we?"
    },

    "error_constraints": [
      "Do not replace 'noka' with 'no'",
      "Do not omit the prefix 'ti-'",
      "Do not combine 'maka' and 'kawilla' in the same clause",
      "Do not place 'we?' inside the sentence",
      "Do not use bare verb forms for ongoing past actions"
    ],

    "model_behavior_guidelines": {
      "enforce_noka_auxiliary": true,
      "enforce_ti_prefix": true,
      "preserve_word_order": true,
      "allow_dual_negation_strategies": true,
      "keep_question_marker_final": true
    }
  }
}


