{
  "instruction_type": "grammar_rule",
  "grammar_name": "balanda_present_perfect",
  "description": "This file defines the Present Perfect tense in Njo Viri (Balanda). The tense expresses actions that have been completed in the past but are relevant at the present moment. It is marked by the particle 'dheki'.",
  "rules": {
    "general_principle": {
      "statement": "Present perfect tense in Balanda is formed using the verb base form followed by the marker 'dheki'. The tense expresses completed actions with present relevance and does not encode a specific past time."
    },

    "affirmative_structure": {
      "structure": "Subject + Verb(base) + (Object / Complement) + dheki",
      "description": "Used to express an action that has been completed and whose result is relevant now.",
      "constraints": [
        "The verb must be in base form",
        "The marker 'dheki' must appear sentence-final",
        "No past tense markers are used"
      ]
    },

    "semantic_scope": {
      "functions": [
        "completed action with present relevance",
        "life experience",
        "result-focused completion",
        "actions without specified past time"
      ]
    },

    "aspect_and_tense_rules": {
      "rule": "Present perfect does not encode tense through verb morphology.",
      "note": "Temporal reference is inferred from context; 'dheki' encodes present relevance."
    },

    "error_constraints": [
      "Do not use past-marked verbs with present perfect",
      "Do not omit 'dheki'",
      "Do not combine 'dheki' with 'taa-' or 'noka'",
      "Do not use present perfect with explicit past time expressions"
    ],

    "model_behavior_guidelines": {
      "enforce_base_verb": true,
      "require_dheki_marker": true,
      "preserve_sentence_final_position": true,
      "map_to_english_present_perfect": true
    }
  }
}

