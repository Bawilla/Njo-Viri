{
  "instruction_type": "grammar_rule",
  "grammar_name": "balanda_present_perfect_questions",
  "description": "This file defines yes–no question formation in the Present Perfect tense in Njo Viri (Balanda). Present perfect questions ask whether an action has occurred up to the present moment.",
  "rules": {
    "general_principle": {
      "statement": "Present perfect questions in Balanda are formed by retaining the affirmative present perfect structure and adding the question marker 'we?' sentence-finally."
    },

    "question_structure": {
      "structure": "Subject + Verb(base) + (Object / Complement) + dheki + we?",
      "constraints": [
        "The verb must remain in base form",
        "The marker 'dheki' must be retained",
        "The question marker 'we?' must appear sentence-final",
        "No auxiliary inversion is used"
      ]
    },

    "aspectual_distinction": {
      "rule": "Present perfect questions do not use 'ti-' and do not use the copula 'ma'."
    },

    "error_constraints": [
      "Do not use 'ma' in present perfect questions",
      "Do not use past-marked verbs",
      "Do not omit 'dheki'",
      "Do not move 'we?' from sentence-final position",
      "Do not combine present perfect with 'ti-'"
    ],

    "model_behavior_guidelines": {
      "enforce_base_verb": true,
      "preserve_dheki_marker": true,
      "require_sentence_final_we": true,
      "map_to_english_present_perfect_questions": true
    }
  }
}


