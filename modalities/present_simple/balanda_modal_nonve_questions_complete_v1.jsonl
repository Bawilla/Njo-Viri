{
  "instruction_type": "grammar_rule",
  "grammar_name": "balanda_present_simple_modal_questions_nonve",
  "description": "This file contains Balanda present simple modal questions using 'nonve'. These sentences express present ability or possibility in interrogative form and correspond to the English meaning 'can'.",
  "rules": {
    "core_meaning": "Present ability or possibility (interrogative)",
    "modal": "nonve",
    "verb_form": "bare verb (base form)",
    "question_form": {
      "structure": "Subject + nonve + VERB + (Object/Complement) + we?",
      "note": "Questions are formed by adding the sentence-final particle 'we?' with no change in word order"
    },
    "tense": "present",
    "aspect": "simple (non-continuous)",
    "polarity": "affirmative",
    "question_marker": "we?",
    "constraints": [
      "nonve must immediately follow the subject",
      "The verb must remain in its base form",
      "No ti- (continuous) or le- (future) prefix may appear",
      "No inversion or auxiliary movement occurs in questions",
      "we? must always appear at the end of the clause",
      "This construction must not be confused with present continuous modal questions (nonve + dho + ti-VERB + we?)"
    ]
  }
}



