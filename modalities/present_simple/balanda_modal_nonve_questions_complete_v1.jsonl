{
  "instruction_type": "grammar_rule",
  "grammar_name": "balanda_present_simple_modal_questions_nonve",
  "description": "This file contains Balanda present simple modal questions using 'nonve'. These sentences express present ability or possibility in interrogative form and correspond to the English meaning 'can'.",
  "rules": {
    "core_meaning": {
      "function": "core meaning",
      "structure": "Present ability or possibility (interrogative)",
      "notes": ""
    },
    "modal": {
      "function": "modal",
      "structure": "nonve",
      "notes": ""
    },
    "verb_form": {
      "function": "verb form",
      "structure": "bare verb (base form)",
      "notes": ""
    },
    "question_form": {
      "function": "question form",
      "structure": "Subject + nonve + VERB + (Object/Complement) + we?",
      "notes": "Questions are formed by adding the sentence-final particle 'we?' with no change in word order"
    },
    "tense": {
      "function": "tense",
      "structure": "present",
      "notes": ""
    },
    "aspect": {
      "function": "aspect",
      "structure": "simple (non-continuous)",
      "notes": ""
    },
    "polarity": {
      "function": "polarity",
      "structure": "affirmative",
      "notes": ""
    },
    "question_marker": {
      "function": "question marker",
      "structure": "we?",
      "notes": ""
    },
    "constraints": {
      "function": "constraints",
      "structure": "nonve must immediately follow the subject; The verb must remain in its base form; No ti- (continuous) or le- (future) prefix may appear; No inversion or auxiliary movement occurs in questions; we? must always appear at the end of the clause; This construction must not be confused with present continuous modal questions (nonve + dho + ti-VERB + we?)",
      "notes": ""
    }
  }
}
