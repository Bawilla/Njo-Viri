{
  "instruction_type": "grammar_rule",
  "grammar_name": "balanda_present_simple_negative_modality_mamve",
  "description": "This file contains Balanda present simple negative modal constructions using 'mamve'. This modality expresses present inability or impossibility and corresponds to the English meaning 'cannot'.",
  "rules": {
    "core_meaning": {
      "function": "core meaning",
      "structure": "Present inability or impossibility",
      "notes": ""
    },
    "modal": {
      "function": "modal",
      "structure": "mamve",
      "notes": ""
    },
    "verb_form": {
      "function": "verb form",
      "structure": "bare verb (base form)",
      "notes": ""
    },
    "negation": {
      "function": "negation",
      "structure": "gba (clause-final)",
      "notes": ""
    },
    "affirmative_negative_form": {
      "function": "affirmative negative form",
      "structure": "Subject + mamve + VERB + (Object/Complement) + gba",
      "notes": "This construction negates present simple modal ability"
    },
    "tense": {
      "function": "tense",
      "structure": "present",
      "notes": ""
    },
    "aspect": {
      "function": "aspect",
      "structure": "simple (non-continuous)",
      "notes": ""
    },
    "polarity": {
      "function": "polarity",
      "structure": "negative",
      "notes": ""
    },
    "constraints": {
      "function": "constraints",
      "structure": "mamve replaces nonve in negative present modality; mamve must immediately follow the subject; The verb must remain in its base form; No ti- (continuous) or le- (future) prefix may appear in this construction; gba must appear at the end of the clause; This construction must not be confused with present continuous negative modality (mamve + dho + ti-VERB + gba)",
      "notes": ""
    }
  }
}
{"instruction":"Translate from Balanda to English","input":"Ne mamve ja nza gba","output":"I cannot eat food."}
{"instruction":"Translate from Balanda to English","input":"Ne mamve nzü ngo gba","output":"I cannot drink water."}
