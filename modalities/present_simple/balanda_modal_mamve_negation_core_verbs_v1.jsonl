{
  "instruction_type": "grammar_rule",
  "grammar_name": "balanda_present_simple_negative_modality_mamve",
  "description": "This file contains Balanda present simple negative modal constructions using 'mamve'. This modality expresses present inability or impossibility and corresponds to the English meaning 'cannot'.",
  "rules": {
    "core_meaning": "Present inability or impossibility",
    "modal": "mamve",
    "verb_form": "bare verb (base form)",
    "negation": "gba (clause-final)",
    "affirmative_negative_form": {
      "structure": "Subject + mamve + VERB + (Object/Complement) + gba",
      "note": "This construction negates present simple modal ability"
    },
    "tense": "present",
    "aspect": "simple (non-continuous)",
    "polarity": "negative",
    "constraints": [
      "mamve replaces nonve in negative present modality",
      "mamve must immediately follow the subject",
      "The verb must remain in its base form",
      "No ti- (continuous) or le- (future) prefix may appear in this construction",
      "gba must appear at the end of the clause",
      "This construction must not be confused with present continuous negative modality (mamve + dho + ti-VERB + gba)"
    ]
  }
}


