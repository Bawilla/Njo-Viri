{
  "instruction_type": "grammar_rule",
  "grammar_name": "balanda_present_simple_modality_nonve",
  "description": "This file contains Balanda present simple modal constructions using 'nonve'. This modality expresses present ability or possibility and corresponds to the English meaning 'can'.",
  "rules": {
    "core_meaning": {
      "function": "core meaning",
      "structure": "Present ability or possibility",
      "notes": ""
    },
    "modal": {
      "function": "modal",
      "structure": "nonve",
      "notes": ""
    },
    "verb_form": {
      "function": "verb form",
      "structure": "bare verb (base form)",
      "notes": ""
    },
    "affirmative_form": {
      "function": "affirmative form",
      "structure": "Subject + nonve + VERB + (Object/Complement)",
      "notes": "This construction expresses present simple modal ability without aspect marking"
    },
    "question_form": {
      "function": "Forms yes/no questions expressing present ability or possibility",
      "structure": "Subject + nonve + VERB + (Object/Complement) + we?",
      "notes": ""
    },
    "tense": {
      "function": "tense",
      "structure": "present",
      "notes": ""
    },
    "aspect": {
      "function": "aspect",
      "structure": "simple (non-continuous)",
      "notes": ""
    },
    "polarity": {
      "function": "polarity",
      "structure": "affirmative",
      "notes": ""
    },
    "constraints": {
      "function": "constraints",
      "structure": "nonve must immediately follow the subject; The verb must remain in its base form; No ti- (continuous) or le- (future) prefix may appear in this construction; No negation marker (gba) appears in affirmative present modality; No word order change occurs in questions; we? always appears at the end of the clause; This construction must not be confused with present continuous modality (nonve + dho + ti-VERB)",
      "notes": ""
    }
  }
}
