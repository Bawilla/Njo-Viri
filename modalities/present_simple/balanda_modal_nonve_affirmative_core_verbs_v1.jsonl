{
  "instruction_type": "grammar_rule",
  "grammar_name": "balanda_present_simple_modality_nonve",
  "description": "This file contains Balanda present simple modal constructions using 'nonve'. This modality expresses present ability or possibility and corresponds to the English meaning 'can'.",
  "rules": {
    "core_meaning": "Present ability or possibility",
    "modal": "nonve",
    "verb_form": "bare verb (base form)",
    "affirmative_form": {
      "structure": "Subject + nonve + VERB + (Object/Complement)",
      "note": "This construction expresses present simple modal ability without aspect marking"
    },
    "question_form": {
      "structure": "Subject + nonve + VERB + (Object/Complement) + we?",
      "function": "Forms yes/no questions expressing present ability or possibility"
    },
    "tense": "present",
    "aspect": "simple (non-continuous)",
    "polarity": "affirmative",
    "constraints": [
      "nonve must immediately follow the subject",
      "The verb must remain in its base form",
      "No ti- (continuous) or le- (future) prefix may appear in this construction",
      "No negation marker (gba) appears in affirmative present modality",
      "No word order change occurs in questions",
      "we? always appears at the end of the clause",
      "This construction must not be confused with present continuous modality (nonve + dho + ti-VERB)"
    ]
  }
}


