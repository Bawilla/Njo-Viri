{
  "instruction_type": "grammar_rule",
  "grammar_name": "balanda_present_continuous_modality_nonve",
  "description": "This file contains Balanda present continuous modal constructions using 'nonve'. This modality expresses present ability or possibility in an ongoing action and corresponds to the English meaning 'can be ...-ing'.",
  "rules": {
    "core_meaning": {
      "function": "core meaning",
      "structure": "Present ability or possibility during an ongoing action",
      "notes": ""
    },
    "modal": {
      "function": "modal",
      "structure": "nonve",
      "notes": ""
    },
    "aspect_marker": {
      "function": "aspect marker",
      "structure": "dho",
      "notes": ""
    },
    "verb_form": {
      "function": "verb form",
      "structure": "ti-VERB (present continuous form)",
      "notes": ""
    },
    "affirmative_form": {
      "function": "affirmative form",
      "structure": "Subject + nonve + dho + ti-VERB + (Object/Complement)",
      "notes": "This construction expresses positive modal meaning with continuous aspect"
    },
    "question_form": {
      "function": "Forms yes/no questions expressing present continuous ability or possibility",
      "structure": "Subject + nonve + dho + ti-VERB + (Object/Complement) + we?",
      "notes": ""
    },
    "tense": {
      "function": "tense",
      "structure": "present",
      "notes": ""
    },
    "aspect": {
      "function": "aspect",
      "structure": "continuous",
      "notes": ""
    },
    "polarity": {
      "function": "polarity",
      "structure": "affirmative",
      "notes": ""
    },
    "constraints": {
      "function": "constraints",
      "structure": "nonve must immediately follow the subject; dho must appear between the modal and the verb; ti- must be retained on the verb; No future marker (le-) may appear in this construction; No negation marker (gba) appears in this file; No word order change occurs in questions; we? always appears at the end of the clause; This construction must not be confused with past continuous modality (nokanve + dho + ti-VERB)",
      "notes": ""
    }
  }
}
{"instruction":"Translate from Balanda to English","input":"Ne nonve dho tija nza","output":"I can be eating food."}
{"instruction":"Translate from Balanda to English","input":"Ne nonve dho tinzü ngo","output":"I can be drinking water."}
{"instruction":"Translate from Balanda to English","input":"Ni nonve dho titeli","output":"He can be sleeping."}
