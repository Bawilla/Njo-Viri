{
  "instruction_type": "grammar_rule",
  "grammar_name": "balanda_past_continuous_modality_nokanve",
  "description": "This file contains Balanda past continuous modal constructions expressing past ability or possibility during an ongoing action. This corresponds to the English meaning 'could be ...-ing'.",
  "rules": {
    "core_meaning": {
      "function": "core meaning",
      "structure": "Past ability or possibility in an ongoing action",
      "notes": ""
    },
    "modal": {
      "function": "modal",
      "structure": "nokanve",
      "notes": ""
    },
    "aspect_marker": {
      "function": "aspect marker",
      "structure": "dho",
      "notes": ""
    },
    "verb_form": {
      "function": "verb form",
      "structure": "ti-VERB (present form retained)",
      "notes": ""
    },
    "affirmative_form": {
      "function": "affirmative form",
      "structure": "Subject + nokanve + dho + ti-VERB + (Object/Complement)",
      "notes": "This construction expresses positive modal meaning without negation"
    },
    "question_form": {
      "function": "Forms yes/no questions expressing past ability or possibility",
      "structure": "Subject + nokanve + dho + ti-VERB + (Object/Complement) + we?",
      "notes": ""
    },
    "tense": {
      "function": "tense",
      "structure": "past",
      "notes": ""
    },
    "aspect": {
      "function": "aspect",
      "structure": "continuous",
      "notes": ""
    },
    "polarity": {
      "function": "polarity",
      "structure": "affirmative",
      "notes": ""
    },
    "constraints": {
      "function": "constraints",
      "structure": "nokanve must precede dho; dho must immediately precede the ti-verb; ti- must not be removed or replaced; No negation marker (gba) appears in this construction; No word order change occurs in questions; This construction must not be used for factual past continuous without modality; The construction expresses modality, not certainty or completed action",
      "notes": ""
    }
  }
}
{"instruction":"Translate from Balanda to English","input":"Ne nokanve dho tija nza","output":"I could be eating food."}
