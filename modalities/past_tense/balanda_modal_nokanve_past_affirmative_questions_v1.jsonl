{
  "instruction_type": "grammar_rule",
  "grammar_name": "balanda_past_positive_modality_nokanve_simple",
  "description": "This file contains Balanda past positive modal constructions using 'nokanve'. This modality expresses past ability or possibility and corresponds to the English meaning 'could'.",
  "rules": {
    "core_meaning": "Past ability or possibility",
    "modal": "nokanve",
    "verb_form": "bare verb (no tense or aspect prefix)",
    "affirmative_form": {
      "structure": "Subject + nokanve + VERB + (Object/Complement)",
      "note": "This construction expresses positive past modality without continuous aspect"
    },
    "question_form": {
      "structure": "Subject + nokanve + VERB + (Object/Complement) + we?",
      "function": "Forms yes/no questions expressing past ability or possibility"
    },
    "tense": "past",
    "aspect": "simple (non-continuous)",
    "polarity": "affirmative",
    "constraints": [
      "nokanve must immediately follow the subject",
      "The verb must remain in its base form",
      "No ti- or le- prefix may appear in this construction",
      "No negation marker (gba) appears in affirmative past modality",
      "No word order change occurs in questions",
      "we? always appears at the end of the clause",
      "This construction must not be confused with past continuous modality (nokanve + dho + ti-VERB)"
    ]
  }
}


