{
  "instruction_type": "grammar_rule",
  "grammar_name": "balanda_past_positive_modality_nokanve_simple",
  "description": "This file contains Balanda past positive modal constructions using 'nokanve'. This modality expresses past ability or possibility and corresponds to the English meaning 'could'.",
  "rules": {
    "core_meaning": {
      "function": "core meaning",
      "structure": "Past ability or possibility",
      "notes": ""
    },
    "modal": {
      "function": "modal",
      "structure": "nokanve",
      "notes": ""
    },
    "verb_form": {
      "function": "verb form",
      "structure": "bare verb (no tense or aspect prefix)",
      "notes": ""
    },
    "affirmative_form": {
      "function": "affirmative form",
      "structure": "Subject + nokanve + VERB + (Object/Complement)",
      "notes": "This construction expresses positive past modality without continuous aspect"
    },
    "question_form": {
      "function": "Forms yes/no questions expressing past ability or possibility",
      "structure": "Subject + nokanve + VERB + (Object/Complement) + we?",
      "notes": ""
    },
    "tense": {
      "function": "tense",
      "structure": "past",
      "notes": ""
    },
    "aspect": {
      "function": "aspect",
      "structure": "simple (non-continuous)",
      "notes": ""
    },
    "polarity": {
      "function": "polarity",
      "structure": "affirmative",
      "notes": ""
    },
    "constraints": {
      "function": "constraints",
      "structure": "nokanve must immediately follow the subject; The verb must remain in its base form; No ti- or le- prefix may appear in this construction; No negation marker (gba) appears in affirmative past modality; No word order change occurs in questions; we? always appears at the end of the clause; This construction must not be confused with past continuous modality (nokanve + dho + ti-VERB)",
      "notes": ""
    }
  }
}
{"instruction":"Translate from Balanda to English","input":"Ne nokanve ja nza","output":"I could eat food."}
{"instruction":"Translate from Balanda to English","input":"Ne nokanve nzü ngo","output":"I could drink water."}
{"instruction":"Translate from Balanda to English","input":"Ni nokanve teli","output":"He could sleep."}
