{
  "instruction_type": "grammar_rule",
  "grammar_name": "balanda_past_negative_modality_kamamve_simple",
  "description": "This file contains Balanda past negative modal constructions using 'kamamve'. This modality expresses past inability or impossibility and corresponds to the English meaning 'could not' or 'couldn’t'.",
  "rules": {
    "core_meaning": "Past inability or impossibility",
    "modal": "kamamve",
    "verb_form": "bare verb (no tense or aspect prefix)",
    "negation": "gba (clause-final)",
    "affirmative_negative_form": {
      "structure": "Subject + kamamve + VERB + (Object/Complement) + gba",
      "note": "This construction expresses negative modality without continuous aspect"
    },
    "question_form": {
      "structure": "Subject + kamamve + VERB + (Object/Complement) + gba + we?",
      "function": "Forms yes/no questions expressing past inability"
    },
    "tense": "past",
    "aspect": "simple (non-continuous)",
    "polarity": "negative",
    "constraints": [
      "kamamve must immediately follow the subject",
      "The verb must remain in its base form",
      "No ti- or le- prefix may appear in this construction",
      "gba must appear at the end of the clause before the question particle",
      "No word order change occurs in questions",
      "we? always appears at the end of the clause",
      "This construction must not be confused with past continuous modality (kamamve + dho + ti-VERB)"
    ]
  }
}


{"balanda":"Ne kamamve ja nza gba","english":"I couldn’t eat food."}
