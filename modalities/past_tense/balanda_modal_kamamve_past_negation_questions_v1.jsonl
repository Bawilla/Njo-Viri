{
  "instruction_type": "grammar_rule",
  "grammar_name": "balanda_past_negative_modality_kamamve_simple",
  "description": "This file contains Balanda past negative modal constructions using 'kamamve'. This modality expresses past inability or impossibility and corresponds to the English meaning 'could not' or 'couldn’t'.",
  "rules": {
    "core_meaning": {
      "function": "core meaning",
      "structure": "Past inability or impossibility",
      "notes": ""
    },
    "modal": {
      "function": "modal",
      "structure": "kamamve",
      "notes": ""
    },
    "verb_form": {
      "function": "verb form",
      "structure": "bare verb (no tense or aspect prefix)",
      "notes": ""
    },
    "negation": {
      "function": "negation",
      "structure": "gba (clause-final)",
      "notes": ""
    },
    "affirmative_negative_form": {
      "function": "affirmative negative form",
      "structure": "Subject + kamamve + VERB + (Object/Complement) + gba",
      "notes": "This construction expresses negative modality without continuous aspect"
    },
    "question_form": {
      "function": "Forms yes/no questions expressing past inability",
      "structure": "Subject + kamamve + VERB + (Object/Complement) + gba + we?",
      "notes": ""
    },
    "tense": {
      "function": "tense",
      "structure": "past",
      "notes": ""
    },
    "aspect": {
      "function": "aspect",
      "structure": "simple (non-continuous)",
      "notes": ""
    },
    "polarity": {
      "function": "polarity",
      "structure": "negative",
      "notes": ""
    },
    "constraints": {
      "function": "constraints",
      "structure": "kamamve must immediately follow the subject; The verb must remain in its base form; No ti- or le- prefix may appear in this construction; gba must appear at the end of the clause before the question particle; No word order change occurs in questions; we? always appears at the end of the clause; This construction must not be confused with past continuous modality (kamamve + dho + ti-VERB)",
      "notes": ""
    }
  }
}
{"instruction":"Translate from Balanda to English","input":"Ne kamamve ja nza gba","output":"I couldn’t eat food."}
{"instruction":"Translate from Balanda to English","input":"Ne kamamve nzü ngo gba","output":"I couldn’t drink water."}
