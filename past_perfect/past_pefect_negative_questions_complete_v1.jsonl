{
  "instruction_type": "grammar_rule",
  "grammar_name": "balanda_past_perfect_negative_questions",
  "description": "This file defines negative yes–no question formation in the Past Perfect tense in Njo Viri (Balanda). Negative questions are formed by adding the sentence-final negation marker 'gba' followed by the question marker 'we?'.",
  "rules": {
    "general_principle": {
      "function": "general principle",
      "structure": "Past perfect negative questions in Balanda retain the past perfect prefix 'taa-' and form negation with sentence-final 'gba', followed by the question marker 'we?'.",
      "notes": ""
    },
    "negative_question_structure": {
      "function": "negative question structure",
      "structure": "Subject + taa-Verb + (Object / Complement) + gba we?",
      "notes": "The prefix 'taa-' must remain attached to the verb; 'gba' must appear before 'we?'; 'we?' must be sentence-final; Word order remains identical to affirmative clauses"
    },
    "preposition_behavior": {
      "function": "preposition behavior",
      "structure": "All prepositions retain their original form and position in negative questions.",
      "notes": "gbi famvara gba we?; ti vili gba we?"
    },
    "error_constraints": {
      "function": "error constraints",
      "structure": "Do not place 'gba' before the verb; Do not separate 'gba' and 'we?'; Do not add auxiliary verbs; Do not modify prepositions",
      "notes": ""
    },
    "model_behavior_guidelines": {
      "function": "model behavior guidelines",
      "structure": "{\"append_gba_before_we\": true, \"preserve_affirmative_word_order\": true, \"do_not_modify_prepositions\": true}",
      "notes": ""
    }
  }
}
