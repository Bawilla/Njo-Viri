{
  "instruction_type": "grammar_rule",
  "grammar_name": "balanda_past_perfect",
  "description": "This file defines the Past Perfect tense in Njo Viri (Balanda). The tense is used to express actions that were completed before another past reference point. It is marked by the prefix 'taa-' attached directly to the verb.",
  "rules": {
    "general_principle": {
      "function": "general principle",
      "structure": "Past perfect tense in Balanda is formed by attaching the prefix 'taa-' to the verb. The tense expresses an action that had already been completed in the past.",
      "notes": ""
    },
    "affirmative_structure": {
      "function": "affirmative structure",
      "structure": "Subject + taa-Verb + (Object / Complement)",
      "notes": "Used to express a completed action prior to another past event. | The prefix 'taa-' must attach directly to the verb root; No auxiliary verb is used; Word order is fixed"
    },
    "verb_morphology": {
      "function": "verb morphology",
      "structure": "taa- is a tense prefix, not a separate word.",
      "notes": "taadhe (had found); taamande (had worked); taamerego (had loved)"
    },
    "error_constraints": {
      "function": "error constraints",
      "structure": "Do not omit the prefix 'taa-'; Do not insert 'no' or 'noka' in past perfect; Do not separate 'taa-' from the verb root",
      "notes": ""
    },
    "model_behavior_guidelines": {
      "function": "model behavior guidelines",
      "structure": "{\"enforce_taa_prefix\": true, \"preserve_word_order\": true, \"restrict_to_completed_actions\": true}",
      "notes": ""
    }
  }
}
