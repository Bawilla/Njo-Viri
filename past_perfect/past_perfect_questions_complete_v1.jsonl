{
  "instruction_type": "grammar_rule",
  "grammar_name": "balanda_past_perfect_questions",
  "description": "This file defines yes–no question formation in the Past Perfect tense in Njo Viri (Balanda). Questions are formed by keeping the past perfect structure unchanged and adding the question marker 'we?' at the end of the sentence.",
  "rules": {
    "general_principle": {
      "statement": "Past perfect questions in Balanda are formed by appending the sentence-final question marker 'we?'. The past perfect prefix 'taa-' and all prepositions remain unchanged."
    },

    "question_structure": {
      "structure": "Subject + taa-Verb + (Object / Complement) + we?",
      "constraints": [
        "The prefix 'taa-' must remain attached to the verb",
        "'we?' must appear sentence-final",
        "No auxiliary verbs are introduced",
        "Word order remains identical to the affirmative form"
      ]
    },

    "preposition_behavior": {
      "rule": "All prepositions retain their original form and position in questions.",
      "examples": [
        "gbi famvara we?",
        "ti vili we?"
      ]
    },

    "error_constraints": [
      "Do not move 'we?' to the middle of the sentence",
      "Do not add 'no' or 'noka'",
      "Do not remove 'taa-' in questions",
      "Do not alter prepositions"
    ],

    "model_behavior_guidelines": {
      "append_we_sentence_final": true,
      "preserve_affirmative_word_order": true,
      "do_not_modify_prepositions": true
    }
  }
}

