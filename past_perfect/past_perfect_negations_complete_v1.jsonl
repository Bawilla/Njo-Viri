{
  "instruction_type": "grammar_rule",
  "grammar_name": "balanda_past_perfect_negation",
  "description": "This file defines negation in the Past Perfect tense in Njo Viri (Balanda). Negation is formed by keeping the past perfect prefix 'taa-' on the verb and adding the sentence-final negation marker 'gba'.",
  "rules": {
    "general_principle": {
      "statement": "Past perfect negation in Balanda is formed by adding the negation marker 'gba' at the end of a past perfect clause. The verbal prefix 'taa-' remains unchanged."
    },

    "negative_structure": {
      "structure": "Subject + taa-Verb + (Object / Complement) + gba",
      "constraints": [
        "The prefix 'taa-' must remain attached to the verb",
        "'gba' must appear sentence-final",
        "No auxiliary verbs are introduced"
      ]
    },

    "preposition_behavior": {
      "rule": "All prepositions remain unchanged under negation.",
      "examples": [
        "gbi famvara gba",
        "ti vili gba"
      ]
    },

    "error_constraints": [
      "Do not remove 'taa-' in negation",
      "Do not place 'gba' before the verb",
      "Do not add 'no' or 'noka'",
      "Do not alter prepositions in negative clauses"
    ],

    "model_behavior_guidelines": {
      "preserve_affirmative_structure": true,
      "append_gba_sentence_final": true,
      "do_not_modify_prepositions": true
    }
  }
}


