{
  "instruction_type": "grammar_rule",
  "grammar_name": "balanda_past_perfect_negation",
  "description": "This file defines negation in the Past Perfect tense in Njo Viri (Balanda). Negation is formed by keeping the past perfect prefix 'taa-' on the verb and adding the sentence-final negation marker 'gba'.",
  "rules": {
    "general_principle": {
      "function": "general principle",
      "structure": "Past perfect negation in Balanda is formed by adding the negation marker 'gba' at the end of a past perfect clause. The verbal prefix 'taa-' remains unchanged.",
      "notes": ""
    },
    "negative_structure": {
      "function": "negative structure",
      "structure": "Subject + taa-Verb + (Object / Complement) + gba",
      "notes": "The prefix 'taa-' must remain attached to the verb; 'gba' must appear sentence-final; No auxiliary verbs are introduced"
    },
    "preposition_behavior": {
      "function": "preposition behavior",
      "structure": "All prepositions remain unchanged under negation.",
      "notes": "gbi famvara gba; ti vili gba"
    },
    "error_constraints": {
      "function": "error constraints",
      "structure": "Do not remove 'taa-' in negation; Do not place 'gba' before the verb; Do not add 'no' or 'noka'; Do not alter prepositions in negative clauses",
      "notes": ""
    },
    "model_behavior_guidelines": {
      "function": "model behavior guidelines",
      "structure": "{\"preserve_affirmative_structure\": true, \"append_gba_sentence_final\": true, \"do_not_modify_prepositions\": true}",
      "notes": ""
    }
  }
}
