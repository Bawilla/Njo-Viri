{
  "instruction_type": "grammar_rule",
  "grammar_name": "balanda_future_continuous_affirmative",
  "description": "This file defines affirmative sentences in the Future Continuous tense in Njo Viri (Balanda). The future continuous tense expresses actions that will be ongoing at a specific time in the future.",
  "rules": {
    "general_principle": {
      "function": "general principle",
      "structure": "Future continuous affirmative sentences in Balanda are formed by combining the future marker 'le-', the auxiliary verb 'dho' (be), and the progressive prefix 'ti-' attached to the verb.",
      "notes": ""
    },
    "affirmative_structure": {
      "function": "affirmative structure",
      "structure": "Subject + le-dho + ti-Verb + (Object / Complement)",
      "notes": "Used to express an action that will be in progress in the future. | The future marker 'le-' must attach to the auxiliary 'dho'; The auxiliary 'dho' must be present; The progressive prefix 'ti-' must attach directly to the verb base; No other tense or aspect markers may appear"
    },
    "tense_and_aspect_roles": {
      "function": "tense and aspect roles",
      "structure": "{\"future_marker\": \"le-\", \"auxiliary\": \"dho (be)\", \"aspect_marker\": \"ti- (progressive)\"}",
      "notes": "le- | dho (be) | ti- (progressive)"
    },
    "word_order_rules": {
      "function": "word order rules",
      "structure": "{\"canonical_order\": [\"Subject\", \"le-dho\", \"ti-Verb\", \"Object / Complement\"]}",
      "notes": "Subject; le-dho; ti-Verb; Object / Complement"
    },
    "error_constraints": {
      "function": "error constraints",
      "structure": "Do not omit 'le-'; Do not omit 'dho'; Do not omit 'ti-'; Do not use 'ma'; Do not use 'dheki'; Do not add 'gba' in affirmative sentences",
      "notes": ""
    },
    "model_behavior_guidelines": {
      "function": "model behavior guidelines",
      "structure": "{\"enforce_le_dho_auxiliary\": true, \"enforce_ti_prefix\": true, \"preserve_word_order\": true, \"block_other_tense_markers\": true, \"map_to_english_future_continuous\": true}",
      "notes": ""
    }
  }
}
