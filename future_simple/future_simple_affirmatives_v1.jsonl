{
  "instruction_type": "grammar_rule",
  "grammar_name": "balanda_future_simple_affirmative",
  "description": "This file defines affirmative sentences in the Future Simple tense in Njo Viri (Balanda). The future simple tense expresses actions that will take place after the moment of speaking.",
  "rules": {
    "general_principle": {
      "statement": "Future simple affirmative sentences in Balanda are formed by attaching the future prefix 'le-' directly to the base form of the verb. No auxiliary verb is used."
    },

    "affirmative_structure": {
      "structure": "Subject + le-Verb(base) + (Object / Complement)",
      "description": "Used to express a definite, planned, or expected future action.",
      "constraints": [
        "The prefix 'le-' must attach directly to the verb base",
        "The verb must not carry any other tense or aspect markers",
        "Objects and complements follow the verb normally"
      ]
    },

    "tense_and_aspect_distinction": {
      "rule": "Future simple in Balanda encodes tense only and does not encode aspect.",
      "note": "The progressive prefix 'ti-' and the result marker 'dheki' must not be used."
    },

    "word_order_rules": {
      "rule": "Word order in future simple affirmatives is identical to basic declarative sentences.",
      "canonical_order": [
        "Subject",
        "le-Verb",
        "Object / Complement"
      ]
    },

    "error_constraints": [
      "Do not omit the prefix 'le-' when expressing future meaning",
      "Do not use the copula 'ma' in affirmative future simple",
      "Do not add the negation marker 'gba'",
      "Do not use the progressive prefix 'ti-'",
      "Do not use the result marker 'dheki'"
    ],

    "model_behavior_guidelines": {
      "enforce_le_prefix": true,
      "enforce_base_verb": true,
      "block_other_tense_markers": true,
      "preserve_word_order": true,
      "map_to_english_future_simple": true
    }
  }
}

