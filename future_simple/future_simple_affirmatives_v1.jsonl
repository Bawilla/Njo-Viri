{
  "instruction_type": "grammar_rule",
  "grammar_name": "balanda_future_simple_affirmative",
  "description": "This file defines affirmative sentences in the Future Simple tense in Njo Viri (Balanda). The future simple tense expresses actions that will take place after the moment of speaking.",
  "rules": {
    "general_principle": {
      "function": "general principle",
      "structure": "Future simple affirmative sentences in Balanda are formed by attaching the future prefix 'le-' directly to the base form of the verb. No auxiliary verb is used.",
      "notes": ""
    },
    "affirmative_structure": {
      "function": "affirmative structure",
      "structure": "Subject + le-Verb(base) + (Object / Complement)",
      "notes": "Used to express a definite, planned, or expected future action. | The prefix 'le-' must attach directly to the verb base; The verb must not carry any other tense or aspect markers; Objects and complements follow the verb normally"
    },
    "tense_and_aspect_distinction": {
      "function": "tense and aspect distinction",
      "structure": "Future simple in Balanda encodes tense only and does not encode aspect.",
      "notes": "The progressive prefix 'ti-' and the result marker 'dheki' must not be used."
    },
    "word_order_rules": {
      "function": "word order rules",
      "structure": "Word order in future simple affirmatives is identical to basic declarative sentences.",
      "notes": "Subject; le-Verb; Object / Complement"
    },
    "error_constraints": {
      "function": "error constraints",
      "structure": "Do not omit the prefix 'le-' when expressing future meaning; Do not use the copula 'ma' in affirmative future simple; Do not add the negation marker 'gba'; Do not use the progressive prefix 'ti-'; Do not use the result marker 'dheki'",
      "notes": ""
    },
    "model_behavior_guidelines": {
      "function": "model behavior guidelines",
      "structure": "{\"enforce_le_prefix\": true, \"enforce_base_verb\": true, \"block_other_tense_markers\": true, \"preserve_word_order\": true, \"map_to_english_future_simple\": true}",
      "notes": ""
    }
  }
}
