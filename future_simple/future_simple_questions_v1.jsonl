{
  "instruction_type": "grammar_rule",
  "grammar_name": "balanda_future_simple_questions",
  "description": "This file defines yes–no question formation in the Future Simple tense in Njo Viri (Balanda). Future simple questions ask whether an action will take place in the future.",
  "rules": {
    "general_principle": {
      "statement": "Future simple questions in Balanda are formed by keeping the affirmative or negative future simple structure unchanged and adding the question marker 'we?' at the end of the sentence."
    },

    "question_structure": {
      "structure": "Affirmative or Negative Future Simple sentence + we?",
      "description": "Used to ask whether a future action will or will not occur.",
      "constraints": [
        "The future prefix 'le-' must remain attached to the verb",
        "Word order must not change",
        "The question marker 'we?' must appear sentence-final"
      ]
    },

    "affirmative_questions": {
      "structure": "Subject + le-Verb(base) + (Object / Complement) + we?",
      "examples": [
        "Ne leyai agbi maraya we?",
        "Ŋo lekonu ndi we?"
      ]
    },

    "negative_questions": {
      "structure": "Subject + le-Verb(base) + (Object / Complement) + gba + we?",
      "examples": [
        "Ne leyai agbi maraya gba we?",
        "Ŋo lekonu ndi gba we?"
      ]
    },

    "tense_and_aspect_distinction": {
      "rule": "Future simple questions encode tense only.",
      "note": "The copula 'ma', the progressive prefix 'ti-', and the result marker 'dheki' must not be used."
    },

    "error_constraints": [
      "Do not omit the prefix 'le-'",
      "Do not move 'we?' from sentence-final position",
      "Do not use 'ma' in future questions",
      "Do not use 'ti-' or 'dheki'",
      "Do not change word order for questions"
    ],

    "model_behavior_guidelines": {
      "enforce_le_prefix": true,
      "keep_word_order_fixed": true,
      "keep_we_sentence_final": true,
      "allow_affirmative_and_negative_questions": true,
      "map_to_english_future_simple_questions": true
    }
  }
}

