{
  "instruction_type": "grammar_rule",
  "grammar_name": "balanda_future_simple_questions",
  "description": "This file defines yes–no question formation in the Future Simple tense in Njo Viri (Balanda). Future simple questions ask whether an action will take place in the future.",
  "rules": {
    "general_principle": {
      "function": "general principle",
      "structure": "Future simple questions in Balanda are formed by keeping the affirmative or negative future simple structure unchanged and adding the question marker 'we?' at the end of the sentence.",
      "notes": ""
    },
    "question_structure": {
      "function": "question structure",
      "structure": "Affirmative or Negative Future Simple sentence + we?",
      "notes": "Used to ask whether a future action will or will not occur. | The future prefix 'le-' must remain attached to the verb; Word order must not change; The question marker 'we?' must appear sentence-final"
    },
    "affirmative_questions": {
      "function": "affirmative questions",
      "structure": "Subject + le-Verb(base) + (Object / Complement) + we?",
      "notes": "Ne leyai agbi maraya we?; Ŋo lekonu ndi we?"
    },
    "negative_questions": {
      "function": "negative questions",
      "structure": "Subject + le-Verb(base) + (Object / Complement) + gba + we?",
      "notes": "Ne leyai agbi maraya gba we?; Ŋo lekonu ndi gba we?"
    },
    "tense_and_aspect_distinction": {
      "function": "tense and aspect distinction",
      "structure": "Future simple questions encode tense only.",
      "notes": "The copula 'ma', the progressive prefix 'ti-', and the result marker 'dheki' must not be used."
    },
    "error_constraints": {
      "function": "error constraints",
      "structure": "Do not omit the prefix 'le-'; Do not move 'we?' from sentence-final position; Do not use 'ma' in future questions; Do not use 'ti-' or 'dheki'; Do not change word order for questions",
      "notes": ""
    },
    "model_behavior_guidelines": {
      "function": "model behavior guidelines",
      "structure": "{\"enforce_le_prefix\": true, \"keep_word_order_fixed\": true, \"keep_we_sentence_final\": true, \"allow_affirmative_and_negative_questions\": true, \"map_to_english_future_simple_questions\": true}",
      "notes": ""
    }
  }
}
