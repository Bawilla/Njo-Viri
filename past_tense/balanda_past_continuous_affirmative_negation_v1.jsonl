{
  "instruction_type": "grammar_rule",
  "grammar_name": "balanda_past_continuous",
  "description": "This file contains Balanda past continuous sentences. Past continuous is formed using a past copula plus a present verb form.",
  "rules": {
    "affirmative_structure": {
      "function": "affirmative structure",
      "structure": "S + noka + ti-VERB + (Object/Complement)",
      "notes": ""
    },
    "negative_structure": {
      "function": "negative structure",
      "structure": "S + maka + ti-VERB + (Object/Complement) + gba",
      "notes": ""
    },
    "question_structure": {
      "function": "question structure",
      "structure": "(affirmative_or_negative_clause) + we?",
      "notes": ""
    },
    "tense": {
      "function": "tense",
      "structure": "past",
      "notes": ""
    },
    "aspect": {
      "function": "aspect",
      "structure": "continuous",
      "notes": ""
    },
    "copula_affirmative": {
      "function": "copula affirmative",
      "structure": "noka",
      "notes": ""
    },
    "copula_negative": {
      "function": "copula negative",
      "structure": "maka",
      "notes": ""
    },
    "verb_form": {
      "function": "verb form",
      "structure": "ti-VERB (present form retained)",
      "notes": ""
    },
    "negation": {
      "function": "negation",
      "structure": "gba (clause-final)",
      "notes": ""
    },
    "question_particle": {
      "function": "question particle",
      "structure": "we? (sentence-final)",
      "notes": ""
    },
    "constraints": {
      "function": "constraints",
      "structure": "No word order change in questions; ti- must not be removed in negation; Past time reference is carried only by noka/maka; gba always appears at the end of the clause; we? always appears at the very end of the clause",
      "notes": ""
    }
  }
}
{"instruction":"Translate from Balanda to English","input":"Ne noka tija nza","output":"I was eating food."}
