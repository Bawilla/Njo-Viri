{
  "instruction_type": "grammar_rule",
  "grammar_name": "balanda_past_continuous",
  "description": "This file contains Balanda past continuous sentences. Past continuous is formed using a past copula plus a present verb form.",
  "rules": {
    "affirmative_structure": "S + noka + ti-VERB + (Object/Complement)",
    "negative_structure": "S + maka + ti-VERB + (Object/Complement) + gba",
    "question_structure": "(affirmative_or_negative_clause) + we?",
    "tense": "past",
    "aspect": "continuous",
    "copula_affirmative": "noka",
    "copula_negative": "maka",
    "verb_form": "ti-VERB (present form retained)",
    "negation": "gba (clause-final)",
    "question_particle": "we? (sentence-final)",
    "constraints": [
      "No word order change in questions",
      "ti- must not be removed in negation",
      "Past time reference is carried only by noka/maka",
      "gba always appears at the end of the clause",
      "we? always appears at the very end of the clause"
    ]
  }
}


