{
  "instruction_type": "grammar_rule",
  "grammar_name": "balanda_past_simple",
  "description": "This file contains Balanda past simple sentences. Past simple expresses completed actions in the past and is formed using the ka- past marker directly on the verb.",
  "rules": {
    "affirmative_structure": "S + ka-VERB + (Object/Complement)",
    "negative_structure": "S + ka-VERB + (Object/Complement) + gba",
    "question_structure": "(affirmative_or_negative_clause) + we?",
    "tense": "past",
    "aspect": "simple",
    "past_marker": "ka- (prefix attached to verb)",
    "verb_form": "bare verb with ka- prefix",
    "negation": "gba (clause-final)",
    "question_particle": "we? (sentence-final)",
    "constraints": [
      "ka- must always be attached directly to the verb",
      "No copula is used in past simple",
      "Negation does not remove ka-",
      "gba always appears at the end of the clause",
      "Questions do not change word order",
      "we? always appears at the very end of the clause",
      "Past simple denotes completed or bounded events"
    ]
  }
}



Affirmative-Past SSimple

{"balanda":"Ne kaja nza","english":"I ate food."}
{"balanda":"Ne kanzü ngo","english":"I drank water."}
{"balanda":"Ni kateli","english":"He slept."}
{"balanda":"Ne kayai a Wau","english":"I went to Wau."}
{"balanda":"Ni kadhii agbi tiyi","english":"He came to the house."}
{"balanda":"Wiki kanono gbi difo","english":"The child walked in the compound."}
{"balanda":"Ni kamande gbi njü","english":"He worked in the garden."}
{"balanda":"Danda kamoliki","english":"We played."}

