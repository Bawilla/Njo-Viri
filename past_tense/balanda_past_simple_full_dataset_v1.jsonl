{
  "instruction_type": "grammar_rule",
  "grammar_name": "balanda_past_simple",
  "description": "This file contains Balanda past simple sentences. Past simple expresses completed actions in the past and is formed using the ka- past marker directly on the verb.",
  "rules": {
    "affirmative_structure": {
      "function": "affirmative structure",
      "structure": "S + ka-VERB + (Object/Complement)",
      "notes": ""
    },
    "negative_structure": {
      "function": "negative structure",
      "structure": "S + ka-VERB + (Object/Complement) + gba",
      "notes": ""
    },
    "question_structure": {
      "function": "question structure",
      "structure": "(affirmative_or_negative_clause) + we?",
      "notes": ""
    },
    "tense": {
      "function": "tense",
      "structure": "past",
      "notes": ""
    },
    "aspect": {
      "function": "aspect",
      "structure": "simple",
      "notes": ""
    },
    "past_marker": {
      "function": "past marker",
      "structure": "ka- (prefix attached to verb)",
      "notes": ""
    },
    "verb_form": {
      "function": "verb form",
      "structure": "bare verb with ka- prefix",
      "notes": ""
    },
    "negation": {
      "function": "negation",
      "structure": "gba (clause-final)",
      "notes": ""
    },
    "question_particle": {
      "function": "question particle",
      "structure": "we? (sentence-final)",
      "notes": ""
    },
    "constraints": {
      "function": "constraints",
      "structure": "ka- must always be attached directly to the verb; No copula is used in past simple; Negation does not remove ka-; gba always appears at the end of the clause; Questions do not change word order; we? always appears at the very end of the clause; Past simple denotes completed or bounded events",
      "notes": ""
    }
  }
}
