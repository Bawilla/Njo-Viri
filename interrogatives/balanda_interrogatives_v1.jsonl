{
  "instruction_type": "grammar_rule",
  "grammar_name": "balanda_interrogatives",
  "description": "This file defines interrogative words and question formation in Njo Viri (Balanda). Interrogatives may appear sentence-final after 'no' or as predicate complements.",

  "rules": {

    "interrogative_words": {
      "yini": "what",
      "dhi": "who",
      "aka": "where",
      "nga": "which",
      "yongo": "when",
      "andini": "why",
      "sowa_yini": "what for",
      "no_nga": "is which ",
      "anga": "which one "
    },

    "general_question_pattern": {
      "pattern": "Clause + no + Interrogative",
      "note": "Many questions place the interrogative after the copula 'no'."
    },

    "examples": [

      {"balanda":"Ŋono no yini?","english":"What is this?"},
      {"balanda":"Ay no yini?","english":"What is it?"},
      {"balanda":"Tiyai no dhi?","english":"Who is going?"},
      {"balanda":"Kateku no dhi?","english":"Who died?"},
      {"balanda":"Nja ŋono no ngandi dhi?","english":"Whose food is this?"},
      {"balanda":"Ŋo tidhe kümü no andini?","english":"Why are you finding wealth?"},
      {"balanda":"Ndi kanangele no andini?","english":"Why did they run?"},
      {"balanda":"Gbulu kanele no andini?","english":"Why did ice melt?"},
      {"balanda":"Ŋo tidhii no yongo?","english":"When are you coming?"},
      {"balanda":"Kese kavoto no yongo?","english":"When did the bike spoil?"},
      {"balanda":"Ay kamati no yongo?","english":"When did it happen?"},
      {"balanda":"Mva no aka?","english":"Where is the knife?"},
      {"balanda":"Kajamini no aka?","english":"Where are the utensils?"},
      {"balanda":"No nga?","english":"Is which?"},
      {"balanda":"Anga?","english":"Which one? (colloquial)"}
    ],

    "error_constraints": [
      "Do not remove the copula 'no' in predicate questions.",
      "Maintain interrogative word position.",
      
    ],

    "model_behavior_guidelines": {
      "enforce_interrogative_position": true,
      "preserve_copula_no": true,
      "distinguish_formal_and_colloquial_forms": true
    }
  }
}