{
  "instruction_type": "lexical_rule",
  "grammar_name": "balanda_core_function_and_verb_lexicon",
  "description": "This file contains core Balanda function words and high-frequency verbs, including the copula, auxiliary-like verbs, modal elements, core action verbs, and discourse particles. These items are foundational to sentence structure and meaning.",
  "rules": {
    "lexical_classes": {
      "copula": {
        "forms": ["No"],
        "function": "Links a subject to a noun, adjective, or locative expression",
        "english_equivalents": ["is", "are"],
        "example": "Ni no gbiya (He is a chief)"
      },
      "possession_verb": {
        "form": "Abi",
        "meaning": "has",
        "example": "Ni abi garra (He has a phone)"
      },
      "core_verbs": {
        "forms": ["baha", "durgu", "iyi", "Dhe", "Zeke", "Duru", "Tima", "Limi", "Dhoti", "Dhii"],
        "function": "Express actions, states, or processes",
        "usage": "Appear as bare verbs in finite clauses"
      },
      "modal_element": {
        "form": "kanonmve",
        "meaning": "would",
        "function": "Expresses conditional or hypothetical modality",
        "constraint": "Does not take tense or aspect markers directly"
      },
      "discourse_particles": {
        "forms": ["Sereme", "Fulu"],
        "functions": {
          "Sereme": "emphasis or intensity (really)",
          "Fulu": "gratitude or politeness (thank)"
        }
      }
    },
    "morphological_properties": {
      "inflection": "none",
      "agreement": "none",
      "tense_marking": "Expressed outside the verb using particles or prefixes already defined"
    },
    "syntactic_usage": {
      "verb_position": "Follows the subject in basic declarative clauses",
      "negation": "Negated using clause-final 'gba'",
      "questions": "Formed by adding sentence-final 'we?'",
      "aspect": "Continuous aspect uses ti- and dho; not inherent to these verbs"
    },
    "constraints": [
      "Copula 'No' must not be treated as a lexical action verb",
      "Function words must not be conjugated",
      "These verbs must not take the infinitive prefix 'A-' when used as finite verbs",
      "Modal elements must not be confused with full lexical verbs",
      "Discourse particles do not function as predicates"
    ]
  }
}




