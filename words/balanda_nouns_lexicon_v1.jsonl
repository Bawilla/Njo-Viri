{
  "instruction_type": "lexical_rule",
  "grammar_name": "balanda_nouns_people_social",
  "description": "This file contains core Balanda nouns referring to people, family relations, age groups, and social roles. These nouns function as independent lexical items and serve as subjects, objects, and complements in sentences.",
  "rules": {
    "part_of_speech": "noun",
    "semantic_domain": [
      "human beings",
      "family relations",
      "social roles",
      "age and status groups"
    ],
    "morphology": {
      "inflection": "none",
      "gender_marking": "lexical (e.g. dhako = man, niki = woman)",
      "number_marking": "Plurality is not marked on the noun itself; plural is expressed with ka- or quantifiers"
    },
    "syntactic_usage": {
      "subject": {
        "example": "Wiki nonve nono (The child can walk)"
      },
      "object": {
        "example": "Ni kolo wiki (He hugs the child)"
      },
      "predicate_nominal": {
        "structure": "NOUN + no + NOUN",
        "example": "Ni no gbiya (He is a chief)"
      }
    },
    "compatibility_rules": {
      "adjectives": "Nouns may be modified by adjectives following the noun (NOUN + ADJECTIVE)",
      "possession": "Nouns may take possessors using 'ngandi' (NOUN + ngandi + POSSESSOR)",
      "quantifiers": "Nouns may combine with quantity words (e.g. makoti, bihi, kpi)",
      "questions": "Nouns participate in questions without changing form"
    },
    "constraints": [
      "Nouns do not take tense, aspect, or modality markers",
      "Nouns are not prefixed with verb markers (A-, ti-, le-)",
      "Gender distinctions are lexical, not grammatical",
      "Social role nouns can function both as common nouns and predicate complements",
      "Do not invent plural suffixes; use ka- or quantifiers instead"
    ]
  }
}



