{
  "instruction_type": "grammar_rule",
  "grammar_name": "balanda_verb_to_have",
  "description": "This file defines the two verbs used to express the meaning of 'to have' in Njo Viri (Balanda): 'abi' and 'ati'. These verbs are not interchangeable and are selected based on the semantic type of possession or state.",
  "rules": {
    "general_principle": {
      "function": "general principle",
      "structure": "Balanda expresses the concept of 'to have' using two distinct verbs: 'abi' for physical possession and obligation, and 'ati' for non-physical states, conditions, and bodily or emotional experiences.",
      "notes": ""
    },
    "abi": {
      "function": "abi",
      "structure": "Abi + Subject + no + Noun / Verb phrase",
      "notes": "to have (physical possession or obligation) | physical objects; jobs or roles; necessity or obligation (have to) | Used for tangible items or concrete possessions; Used to express obligation or necessity; Not used for feelings, illnesses, or abstract states | Abi ne no tamma; Abi ni no kese; Abi ndi no ayai; Abi Uku no nde"
    },
    "ati": {
      "function": "ati",
      "structure": "Ati + Subject + no + State / Condition",
      "notes": "to have (non-physical states or conditions) | feelings and sensations; illness or bodily conditions; states or qualities; asking what is wrong with someone | Used only for non-physical or abstract conditions; Commonly used for hunger, pain, sickness, emotions, and states; Cannot be used for physical possession | Ati ne no goho; Ati ni no kumuru; Ati ŋo no veti; Ati ŋo no yini?"
    },
    "copula_usage": {
      "function": "copula usage",
      "structure": "Both 'abi' and 'ati' require the copula 'no' to link the subject with the possessed item or state.",
      "notes": "The copula agrees with present-time statements."
    },
    "error_constraints": {
      "function": "error constraints",
      "structure": "Do not use 'ati' for physical objects; Do not use 'abi' for feelings, sickness, or states; Do not omit the copula 'no'; Do not interchange 'abi' and 'ati'",
      "notes": ""
    },
    "model_behavior_guidelines": {
      "function": "model behavior guidelines",
      "structure": "{\"treat_abi_and_ati_as_distinct_verbs\": true, \"enforce_semantic_selection\": true, \"preserve_copula_no\": true, \"map_to_english_have_contextually\": true}",
      "notes": ""
    }
  }
}
