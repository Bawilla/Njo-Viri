{
  "instruction_type": "lexical_rule",
  "grammar_name": "balanda_adjectives_core",
  "description": "This file contains core Balanda adjectives and descriptive words. These words express qualities, states, quantities, and attributes. Adjectives in Balanda are not inflected for number or gender and remain invariable.",
  "rules": {
    "part_of_speech": "adjective",
    "morphology": {
      "inflection": "none",
      "agreement": "Adjectives do not agree with nouns in number, gender, or class",
      "form": "Adjectives appear as fixed lexical forms"
    },
    "semantic_categories": {
      "quality": ["mayivi", "mavö", "makiti", "makpokoro"],
      "size_dimension": ["maga", "manjite", "manza", "lotü", "mafere", "makpidiri"],
      "speed": ["mazanga", "mabito"],
      "age_state": ["ngu", "magamara", "mazongo"],
      "cleanliness_condition": ["mamgbala", "maveti", "madoko", "majï"],
      "life_state": ["wunga"],
      "light_visual": ["mamgbara", "madhiki"],
      "shape_form": ["madingili", "magbaka", "matara"],
      "thickness": ["makeŋi", "mamïtïrï"],
      "quantity_determiner": ["makoti", "maroko", "kpi", "bihi"],
      "order_relation": ["kokono", "suku", "kpendele"],
      "focus_emphasis": ["gama", "kelegere", "kala"],
      "emotional_state": ["manayi", "manoko"]
    },
    "syntactic_usage": {
      "attributive": {
        "structure": "NOUN + ADJECTIVE",
        "example": "Wiki mayivi (good child)"
      },
      "predicative": {
        "structure": "NOUN + ADJECTIVE",
        "example": "Wiki mayivi (The child is good)"
      }
    },
    "polysemy_rules": {
      "manza": "Can mean both 'long' and 'tall' depending on the noun it modifies"
    },
    "constraints": [
      "Adjectives must not be conjugated",
      "Adjectives must not take tense or aspect markers",
      "Adjectives must not be prefixed with verb markers",
      "Quantifiers like 'kpi' and 'bihi' behave adjectivally but may also function as determiners",
      "Do not invent comparative or superlative morphology unless explicitly attested"
    ]
  }
}



