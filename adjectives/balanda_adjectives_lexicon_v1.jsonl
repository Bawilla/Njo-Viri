      "notes": "none | Adjectives do not agree with nouns in number, gender, or class | Adjectives appear as fixed lexical forms"
    },
    "semantic_categories": {
      "function": "semantic categories",
      "structure": "{\"quality\": [\"mayivi\", \"mavö\", \"makiti\", \"makpokoro\"], \"size_dimension\": [\"maga\", \"manjite\", \"manza\", \"lotü\", \"mafere\", \"makpidiri\"], \"speed\": [\"mazanga\", \"mabito\"], \"age_state\": [\"ngu\", \"magamara\", \"mazongo\"], \"cleanliness_condition\": [\"mamgbala\", \"maveti\", \"madoko\", \"majï\"], \"life_state\": [\"wunga\"], \"light_visual\": [\"mamgbara\", \"madhiki\"], \"shape_form\": [\"madingili\", \"magbaka\", \"matara\"], \"thickness\": [\"makeŋi\", \"mamïtïrï\"], \"quantity_determiner\": [\"makoti\", \"maroko\", \"kpi\", \"bihi\"], \"order_relation\": [\"kokono\", \"suku\", \"kpendele\"], \"focus_emphasis\": [\"gama\", \"kelegere\", \"kala\"], \"emotional_state\": [\"manayi\", \"manoko\"]}",
      "notes": "mayivi; mavö; makiti; makpokoro | maga; manjite; manza; lotü; mafere; makpidiri | mazanga; mabito | ngu; magamara; mazongo | mamgbala; maveti; madoko; majï | wunga | mamgbara; madhiki | madingili; magbaka; matara | makeŋi; mamïtïrï | makoti; maroko; kpi; bihi | kokono; suku; kpendele | gama; kelegere; kala | manayi; manoko"
    },
    "syntactic_usage": {
      "function": "syntactic usage",
      "structure": "{\"attributive\": {\"structure\": \"NOUN + ADJECTIVE\", \"example\": \"Wiki mayivi (good child)\"}, \"predicative\": {\"structure\": \"NOUN + ADJECTIVE\", \"example\": \"Wiki mayivi (The child is good)\"}}",
      "notes": ""
    },
    "polysemy_rules": {
      "function": "polysemy rules",
      "structure": "{\"manza\": \"Can mean both 'long' and 'tall' depending on the noun it modifies\"}",
      "notes": "Can mean both 'long' and 'tall' depending on the noun it modifies"
    },
    "constraints": {
      "function": "constraints",
      "structure": "Adjectives must not be conjugated; Adjectives must not take tense or aspect markers; Adjectives must not be prefixed with verb markers; Quantifiers like 'kpi' and 'bihi' behave adjectivally but may also function as determiners; Do not invent comparative or superlative morphology unless explicitly attested",
      "notes": ""
    }
  }
}
